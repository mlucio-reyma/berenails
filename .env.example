# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno requeridas
#
# 1. Copia este archivo:  cp .env.example .env.local
# 2. Rellena los valores con tus credenciales reales
# 3. NUNCA subas .env.local al repositorio (está en .gitignore)
#
# En GitHub Actions configura estos valores como Secrets:
#   Settings → Secrets and variables → Actions → New repository secret
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — console.supabase.com → Tu proyecto → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App
VITE_APP_ENV=development
